{
  "name": "app-name",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter client dev\" \"pnpm --filter server start:dev\"",
    "build": "pnpm --filter client build && pnpm --filter server build",
    "start:prod": "pnpm --filter server start:prod",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter client exec tsc -b --noEmit && pnpm --filter server exec tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
